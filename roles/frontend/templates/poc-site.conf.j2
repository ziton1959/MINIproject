server {
    listen 80 default_server;
    server_name _;

    root /var/www/poc;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location /api/ {
        proxy_pass http://{{ app_ip }}:{{ app_port }}/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
